--- /dev/null
+++ b/src/terminal/wasm_api.zig
@@ -0,0 +1,1034 @@
+//! WASM API for the Terminal emulator.
+//!
+//! Provides a minimal, high-performance C interface to Ghostty's Terminal
+//! for WASM export. Reads directly from the terminal's screen buffer
+//! for maximum efficiency.
+//!
+//! API Design:
+//! - Lifecycle: new, free, resize, write, set_colors
+//! - Rendering: get_viewport, get_cursor_*, get_*_color
+//! - Modes: is_alternate_screen, has_mouse_tracking, get_mode
+//! - Scrollback: get_scrollback_length, get_scrollback_line
+//! - Responses: has_response, read_response
+
+const std = @import("std");
+const Allocator = std.mem.Allocator;
+const builtin = @import("builtin");
+
+const Terminal = @import("Terminal.zig");
+const stream = @import("stream.zig");
+const ansi = @import("ansi.zig");
+const color = @import("color.zig");
+const modespkg = @import("modes.zig");
+const point = @import("point.zig");
+const pagepkg = @import("page.zig");
+const Style = @import("style.zig").Style;
+const Screen = @import("Screen.zig");
+const device_status = @import("device_status.zig");
+const charsets = @import("charsets.zig");
+const csi = @import("csi.zig");
+const sgr = @import("sgr.zig");
+
+const log = std.log.scoped(.wasm_api);
+
+/// Stream handler that processes VT sequences and applies them to the terminal.
+/// Implements the callback-based interface that stream.Stream checks via @hasDecl.
+const Handler = struct {
+    alloc: Allocator,
+    terminal: *Terminal,
+    response_buffer: *std.ArrayList(u8),
+
+    // --- Core character output ---
+
+    pub fn print(self: *Handler, cp: u21) !void {
+        try self.terminal.print(cp);
+    }
+
+    pub fn printRepeat(self: *Handler, count: usize) !void {
+        try self.terminal.printRepeat(count);
+    }
+
+    // --- C0 controls ---
+
+    pub fn bell(self: *Handler) !void {
+        _ = self;
+    }
+
+    pub fn backspace(self: *Handler) !void {
+        self.terminal.backspace();
+    }
+
+    pub fn horizontalTab(self: *Handler, count: u16) !void {
+        for (0..count) |_| {
+            const x = self.terminal.screen.cursor.x;
+            try self.terminal.horizontalTab();
+            if (x == self.terminal.screen.cursor.x) break;
+        }
+    }
+
+    pub fn horizontalTabBack(self: *Handler, count: u16) !void {
+        for (0..count) |_| {
+            const x = self.terminal.screen.cursor.x;
+            try self.terminal.horizontalTabBack();
+            if (x == self.terminal.screen.cursor.x) break;
+        }
+    }
+
+    pub fn linefeed(self: *Handler) !void {
+        try self.terminal.linefeed();
+    }
+
+    pub fn carriageReturn(self: *Handler) !void {
+        self.terminal.carriageReturn();
+    }
+
+    pub fn invokeCharset(
+        self: *Handler,
+        active: charsets.ActiveSlot,
+        slot: charsets.Slots,
+        single: bool,
+    ) !void {
+        self.terminal.invokeCharset(active, slot, single);
+    }
+
+    pub fn configureCharset(
+        self: *Handler,
+        slot: charsets.Slots,
+        set: charsets.Charset,
+    ) !void {
+        self.terminal.configureCharset(slot, set);
+    }
+
+    // --- Cursor movement ---
+
+    pub fn setCursorUp(self: *Handler, count: u16, private: bool) !void {
+        _ = private;
+        self.terminal.cursorUp(count);
+    }
+
+    pub fn setCursorDown(self: *Handler, count: u16, private: bool) !void {
+        _ = private;
+        self.terminal.cursorDown(count);
+    }
+
+    pub fn setCursorRight(self: *Handler, count: u16) !void {
+        self.terminal.cursorRight(count);
+    }
+
+    pub fn setCursorLeft(self: *Handler, count: u16) !void {
+        self.terminal.cursorLeft(count);
+    }
+
+    pub fn setCursorPos(self: *Handler, row: u16, col: u16) !void {
+        self.terminal.setCursorPos(row, col);
+    }
+
+    pub fn setCursorCol(self: *Handler, col: u16) !void {
+        self.terminal.setCursorPos(
+            self.terminal.screen.cursor.y + 1,
+            col,
+        );
+    }
+
+    pub fn setCursorRow(self: *Handler, row: u16) !void {
+        self.terminal.setCursorPos(
+            row,
+            self.terminal.screen.cursor.x + 1,
+        );
+    }
+
+    pub fn setCursorColRelative(self: *Handler, offset: u16) !void {
+        self.terminal.setCursorPos(
+            self.terminal.screen.cursor.y + 1,
+            self.terminal.screen.cursor.x + 1 +| offset,
+        );
+    }
+
+    pub fn setCursorRowRelative(self: *Handler, offset: u16) !void {
+        self.terminal.setCursorPos(
+            self.terminal.screen.cursor.y + 1 +| offset,
+            self.terminal.screen.cursor.x + 1,
+        );
+    }
+
+    pub fn setCursorStyle(self: *Handler, style: ansi.CursorStyle) !void {
+        const blink = switch (style) {
+            .default, .steady_block, .steady_bar, .steady_underline => false,
+            .blinking_block, .blinking_bar, .blinking_underline => true,
+        };
+        const cursor_style: Screen.CursorStyle = switch (style) {
+            .default, .blinking_block, .steady_block => .block,
+            .blinking_bar, .steady_bar => .bar,
+            .blinking_underline, .steady_underline => .underline,
+        };
+        self.terminal.modes.set(.cursor_blinking, blink);
+        self.terminal.screen.cursor.cursor_style = cursor_style;
+    }
+
+    // --- Editing ---
+
+    pub fn eraseDisplay(self: *Handler, mode: csi.EraseDisplay, protected: bool) !void {
+        self.terminal.eraseDisplay(mode, protected);
+    }
+
+    pub fn eraseLine(self: *Handler, mode: csi.EraseLine, protected: bool) !void {
+        self.terminal.eraseLine(mode, protected);
+    }
+
+    pub fn deleteChars(self: *Handler, count: usize) !void {
+        self.terminal.deleteChars(count);
+    }
+
+    pub fn eraseChars(self: *Handler, count: usize) !void {
+        self.terminal.eraseChars(count);
+    }
+
+    pub fn insertLines(self: *Handler, count: usize) !void {
+        self.terminal.insertLines(count);
+    }
+
+    pub fn insertBlanks(self: *Handler, count: usize) !void {
+        self.terminal.insertBlanks(count);
+    }
+
+    pub fn deleteLines(self: *Handler, count: usize) !void {
+        self.terminal.deleteLines(count);
+    }
+
+    // --- Scrolling ---
+
+    pub fn scrollUp(self: *Handler, count: usize) !void {
+        self.terminal.scrollUp(count);
+    }
+
+    pub fn scrollDown(self: *Handler, count: usize) !void {
+        self.terminal.scrollDown(count);
+    }
+
+    // --- Tabs ---
+
+    pub fn tabSet(self: *Handler) !void {
+        self.terminal.tabSet();
+    }
+
+    pub fn tabClear(self: *Handler, cmd: csi.TabClear) !void {
+        self.terminal.tabClear(cmd);
+    }
+
+    pub fn tabReset(self: *Handler) !void {
+        self.terminal.tabReset();
+    }
+
+    // --- Modes ---
+
+    pub fn setMode(self: *Handler, mode: modespkg.Mode, enabled: bool) !void {
+        self.terminal.modes.set(mode, enabled);
+        switch (mode) {
+            .autorepeat, .reverse_colors => {},
+            .origin => self.terminal.setCursorPos(1, 1),
+            .enable_left_and_right_margin => if (!enabled) {
+                self.terminal.scrolling_region.left = 0;
+                self.terminal.scrolling_region.right = self.terminal.cols - 1;
+            },
+            .alt_screen_legacy => self.terminal.switchScreenMode(.@"47", enabled),
+            .alt_screen => self.terminal.switchScreenMode(.@"1047", enabled),
+            .alt_screen_save_cursor_clear_enter => self.terminal.switchScreenMode(.@"1049", enabled),
+            .save_cursor => if (enabled) {
+                self.terminal.saveCursor();
+            } else {
+                try self.terminal.restoreCursor();
+            },
+            .enable_mode_3 => {},
+            .@"132_column" => try self.terminal.deccolm(
+                self.alloc,
+                if (enabled) .@"132_cols" else .@"80_cols",
+            ),
+            else => {},
+        }
+    }
+
+    pub fn saveMode(self: *Handler, mode: modespkg.Mode) !void {
+        self.terminal.modes.save(mode);
+    }
+
+    pub fn restoreMode(self: *Handler, mode: modespkg.Mode) !void {
+        const v = self.terminal.modes.restore(mode);
+        try self.setMode(mode, v);
+    }
+
+    // --- Margins ---
+
+    pub fn setTopAndBottomMargin(self: *Handler, top: u16, bottom: u16) !void {
+        self.terminal.setTopAndBottomMargin(top, bottom);
+    }
+
+    pub fn setLeftAndRightMargin(self: *Handler, left: u16, right: u16) !void {
+        self.terminal.setLeftAndRightMargin(left, right);
+    }
+
+    pub fn setLeftAndRightMarginAmbiguous(self: *Handler) !void {
+        if (self.terminal.modes.get(.enable_left_and_right_margin)) {
+            self.terminal.setLeftAndRightMargin(0, 0);
+        } else {
+            self.terminal.saveCursor();
+        }
+    }
+
+    // --- Cursor save/restore ---
+
+    pub fn saveCursor(self: *Handler) !void {
+        self.terminal.saveCursor();
+    }
+
+    pub fn restoreCursor(self: *Handler) !void {
+        try self.terminal.restoreCursor();
+    }
+
+    // --- Attributes ---
+
+    pub fn setAttribute(self: *Handler, attr: sgr.Attribute) !void {
+        switch (attr) {
+            .unknown => {},
+            else => try self.terminal.setAttribute(attr),
+        }
+    }
+
+    pub fn setProtectedMode(self: *Handler, mode: ansi.ProtectedMode) !void {
+        self.terminal.setProtectedMode(mode);
+    }
+
+    pub fn setMouseShiftCapture(self: *Handler, capture: bool) !void {
+        self.terminal.flags.mouse_shift_capture = if (capture) .true else .false;
+    }
+
+    // --- Kitty keyboard ---
+
+    pub fn pushKittyKeyboard(self: *Handler, flags: u8) !void {
+        self.terminal.screen.kitty_keyboard.push(flags);
+    }
+
+    pub fn popKittyKeyboard(self: *Handler, n: u16) !void {
+        self.terminal.screen.kitty_keyboard.pop(@intCast(n));
+    }
+
+    pub fn setKittyKeyboard(self: *Handler, mode: u8, flags: u8) !void {
+        self.terminal.screen.kitty_keyboard.set(@enumFromInt(mode), flags);
+    }
+
+    // --- Modify key format ---
+
+    pub fn setModifyKeyFormat(self: *Handler, format: ansi.ModifyKeyFormat) !void {
+        self.terminal.flags.modify_other_keys_2 = false;
+        switch (format) {
+            .other_keys_numeric => self.terminal.flags.modify_other_keys_2 = true,
+            else => {},
+        }
+    }
+
+    // --- Status display ---
+
+    pub fn setActiveStatusDisplay(self: *Handler, display: ansi.StatusDisplay) !void {
+        self.terminal.status_display = display;
+    }
+
+    // --- Misc terminal operations ---
+
+    pub fn index(self: *Handler) !void {
+        try self.terminal.index();
+    }
+
+    pub fn nextLine(self: *Handler) !void {
+        try self.terminal.index();
+        self.terminal.carriageReturn();
+    }
+
+    pub fn reverseIndex(self: *Handler) !void {
+        self.terminal.reverseIndex();
+    }
+
+    pub fn decaln(self: *Handler) !void {
+        try self.terminal.decaln();
+    }
+
+    pub fn fullReset(self: *Handler) !void {
+        self.terminal.fullReset();
+    }
+
+    // --- Hyperlinks ---
+
+    pub fn startHyperlink(self: *Handler, uri: []const u8, id: ?[]const u8) !void {
+        try self.terminal.screen.startHyperlink(uri, id);
+    }
+
+    pub fn endHyperlink(self: *Handler) !void {
+        self.terminal.screen.endHyperlink();
+    }
+
+    // --- Semantic prompts ---
+
+    pub fn promptStart(self: *Handler, aid: ?[]const u8, redraw: bool) !void {
+        _ = aid;
+        self.terminal.screen.cursor.page_row.semantic_prompt = .prompt;
+        self.terminal.flags.shell_redraws_prompt = redraw;
+    }
+
+    pub fn promptEnd(self: *Handler) !void {
+        self.terminal.markSemanticPrompt(.input);
+    }
+
+    pub fn endOfInput(self: *Handler) !void {
+        self.terminal.markSemanticPrompt(.command);
+    }
+
+    pub fn endOfCommand(self: *Handler) !void {
+        self.terminal.screen.cursor.page_row.semantic_prompt = .input;
+    }
+
+    // --- Device status ---
+
+    pub fn deviceStatusReport(self: *Handler, req: device_status.Request) !void {
+        switch (req) {
+            .operating_status => {
+                try self.response_buffer.appendSlice("\x1B[0n");
+            },
+            .cursor_position => {
+                const cursor = self.terminal.screen.cursor;
+                const x = if (self.terminal.modes.get(.origin))
+                    cursor.x -| self.terminal.scrolling_region.left
+                else
+                    cursor.x;
+                const y = if (self.terminal.modes.get(.origin))
+                    cursor.y -| self.terminal.scrolling_region.top
+                else
+                    cursor.y;
+                var buf: [32]u8 = undefined;
+                const resp = std.fmt.bufPrint(&buf, "\x1B[{};{}R", .{
+                    y + 1,
+                    x + 1,
+                }) catch return;
+                try self.response_buffer.appendSlice(resp);
+            },
+            else => {},
+        }
+    }
+
+    pub fn deviceAttributes(self: *Handler, req: ansi.DeviceAttributeReq, params: []const u16) !void {
+        _ = params;
+        switch (req) {
+            .primary => {
+                try self.response_buffer.appendSlice("\x1B[?62;22c");
+            },
+            .secondary => {
+                try self.response_buffer.appendSlice("\x1B[>1;10;0c");
+            },
+            else => {},
+        }
+    }
+
+    // --- Mouse shape ---
+
+    pub fn setMouseShape(self: *Handler, shape: @import("mouse_shape.zig").MouseShape) !void {
+        self.terminal.mouse_shape = shape;
+    }
+
+    // --- No-op callbacks (needed for completeness but no terminal effect) ---
+
+    pub fn changeWindowTitle(self: *Handler, title: []const u8) !void {
+        _ = self;
+        _ = title;
+    }
+
+    pub fn reportPwd(self: *Handler, url: []const u8) !void {
+        _ = self;
+        _ = url;
+    }
+};
+
+/// The stream type using our handler
+const TermStream = stream.Stream(*Handler);
+
+/// Wrapper struct that owns the Terminal, stream, and response buffer.
+const TerminalWrapper = struct {
+    alloc: Allocator,
+    terminal: Terminal,
+    handler: Handler,
+    s: TermStream,
+    /// Response buffer for DSR and other query responses
+    response_buffer: std.ArrayList(u8),
+    /// Custom foreground/background colors (set at creation or via setColors)
+    fg_color: color.RGB,
+    bg_color: color.RGB,
+    cursor_color: color.RGB,
+};
+
+/// C-compatible cell structure (16 bytes)
+pub const GhosttyCell = extern struct {
+    codepoint: u32,
+    fg_r: u8,
+    fg_g: u8,
+    fg_b: u8,
+    bg_r: u8,
+    bg_g: u8,
+    bg_b: u8,
+    flags: u8,
+    width: u8,
+    hyperlink_id: u16,
+    grapheme_len: u8 = 0,
+    _pad: u8 = 0,
+};
+
+/// C-compatible terminal configuration
+pub const GhosttyTerminalConfig = extern struct {
+    scrollback_limit: u32,
+    fg_color: u32,
+    bg_color: u32,
+    cursor_color: u32,
+    palette: [16]u32,
+};
+
+const default_fg: color.RGB = .{ .r = 204, .g = 204, .b = 204 };
+const default_bg: color.RGB = .{ .r = 0, .g = 0, .b = 0 };
+const default_cursor_color: color.RGB = .{ .r = 204, .g = 204, .b = 204 };
+
+fn parseRGB(packed: u32) color.RGB {
+    return .{
+        .r = @truncate((packed >> 16) & 0xFF),
+        .g = @truncate((packed >> 8) & 0xFF),
+        .b = @truncate(packed & 0xFF),
+    };
+}
+
+fn packRGB(rgb: color.RGB) u32 {
+    return (@as(u32, rgb.r) << 16) | (@as(u32, rgb.g) << 8) | rgb.b;
+}
+
+// ============================================================================
+// Lifecycle
+// ============================================================================
+
+pub fn new(cols: c_int, rows: c_int) callconv(.c) ?*anyopaque {
+    return newWithConfig(cols, rows, null);
+}
+
+pub fn newWithConfig(
+    cols: c_int,
+    rows: c_int,
+    config_: ?*const GhosttyTerminalConfig,
+) callconv(.c) ?*anyopaque {
+    const alloc = if (builtin.target.cpu.arch.isWasm())
+        std.heap.wasm_allocator
+    else
+        std.heap.c_allocator;
+
+    const wrapper = alloc.create(TerminalWrapper) catch return null;
+
+    const scrollback_limit: usize = if (config_) |cfg|
+        if (cfg.scrollback_limit == 0) std.math.maxInt(usize) else cfg.scrollback_limit
+    else
+        10_000;
+
+    // Parse colors from config
+    var fg = default_fg;
+    var bg = default_bg;
+    var cursor_col = default_cursor_color;
+
+    if (config_) |cfg| {
+        if (cfg.fg_color != 0) fg = parseRGB(cfg.fg_color);
+        if (cfg.bg_color != 0) bg = parseRGB(cfg.bg_color);
+        if (cfg.cursor_color != 0) cursor_col = parseRGB(cfg.cursor_color);
+    }
+
+    var term = Terminal.init(alloc, .{
+        .cols = @intCast(cols),
+        .rows = @intCast(rows),
+        .max_scrollback = scrollback_limit,
+    }) catch {
+        alloc.destroy(wrapper);
+        return null;
+    };
+
+    // Apply palette colors from config
+    if (config_) |cfg| {
+        for (cfg.palette, 0..) |palette_color, i| {
+            if (palette_color != 0) {
+                term.color_palette.colors[i] = parseRGB(palette_color);
+                term.default_palette[i] = parseRGB(palette_color);
+            }
+        }
+    }
+
+    // Enable grapheme clustering (mode 2027) by default for proper Unicode support.
+    term.modes.set(.grapheme_cluster, true);
+
+    // linefeed mode must be FALSE to match native terminal behavior
+    term.modes.set(.linefeed, false);
+
+    wrapper.* = .{
+        .alloc = alloc,
+        .terminal = term,
+        .handler = undefined,
+        .s = undefined,
+        .response_buffer = .empty,
+        .fg_color = fg,
+        .bg_color = bg,
+        .cursor_color = cursor_col,
+    };
+
+    // Set up handler with references into wrapper
+    wrapper.handler = .{
+        .alloc = alloc,
+        .terminal = &wrapper.terminal,
+        .response_buffer = &wrapper.response_buffer,
+    };
+
+    wrapper.s = .init(&wrapper.handler);
+
+    return @ptrCast(wrapper);
+}
+
+pub fn free(ptr: ?*anyopaque) callconv(.c) void {
+    const wrapper: *TerminalWrapper = @ptrCast(@alignCast(ptr orelse return));
+    const alloc = wrapper.alloc;
+    wrapper.response_buffer.deinit(alloc);
+    wrapper.terminal.deinit(alloc);
+    alloc.destroy(wrapper);
+}
+
+pub fn resize(ptr: ?*anyopaque, cols: c_int, rows: c_int) callconv(.c) void {
+    const wrapper: *TerminalWrapper = @ptrCast(@alignCast(ptr orelse return));
+    wrapper.terminal.resize(wrapper.alloc, @intCast(cols), @intCast(rows)) catch return;
+}
+
+pub fn write(ptr: ?*anyopaque, data: [*]const u8, len: usize) callconv(.c) void {
+    const wrapper: *TerminalWrapper = @ptrCast(@alignCast(ptr orelse return));
+    wrapper.s.nextSlice(data[0..len]) catch return;
+}
+
+/// Update terminal colors at runtime
+pub fn setColors(ptr: ?*anyopaque, config_: ?*const GhosttyTerminalConfig) callconv(.c) void {
+    const wrapper: *TerminalWrapper = @ptrCast(@alignCast(ptr orelse return));
+    const cfg = config_ orelse return;
+
+    if (cfg.fg_color != 0) wrapper.fg_color = parseRGB(cfg.fg_color);
+    if (cfg.bg_color != 0) wrapper.bg_color = parseRGB(cfg.bg_color);
+    if (cfg.cursor_color != 0) wrapper.cursor_color = parseRGB(cfg.cursor_color);
+
+    for (cfg.palette, 0..) |palette_color, i| {
+        if (palette_color != 0) {
+            wrapper.terminal.color_palette.colors[i] = parseRGB(palette_color);
+        }
+    }
+}
+
+// ============================================================================
+// Rendering API
+// ============================================================================
+
+pub fn getCols(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return @intCast(wrapper.terminal.cols);
+}
+
+pub fn getRows(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return @intCast(wrapper.terminal.rows);
+}
+
+pub fn getCursorX(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return @intCast(wrapper.terminal.screen.cursor.x);
+}
+
+pub fn getCursorY(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return @intCast(wrapper.terminal.screen.cursor.y);
+}
+
+pub fn getCursorVisible(ptr: ?*anyopaque) callconv(.c) bool {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    return wrapper.terminal.modes.get(.cursor_visible);
+}
+
+pub fn getBgColor(ptr: ?*anyopaque) callconv(.c) u32 {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return packRGB(wrapper.bg_color);
+}
+
+pub fn getFgColor(ptr: ?*anyopaque) callconv(.c) u32 {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0xCCCCCC));
+    return packRGB(wrapper.fg_color);
+}
+
+/// Helper to resolve a cell's colors and flags into a GhosttyCell
+fn resolveCell(
+    cell: *const pagepkg.Cell,
+    page: *const pagepkg.Page,
+    fg_default: color.RGB,
+    bg_default: color.RGB,
+    palette: *const color.Palette,
+) GhosttyCell {
+    const sty: Style = if (cell.style_id > 0)
+        page.styles.get(page.memory, cell.style_id).*
+    else
+        .{};
+
+    const fg: color.RGB = switch (sty.fg_color) {
+        .none => fg_default,
+        .palette => |i| palette[i],
+        .rgb => |rgb| rgb,
+    };
+    const bg: color.RGB = if (sty.bg(cell, palette)) |rgb| rgb else bg_default;
+
+    var flags: u8 = 0;
+    if (sty.flags.bold) flags |= 1 << 0;
+    if (sty.flags.italic) flags |= 1 << 1;
+    if (sty.flags.underline != .none) flags |= 1 << 2;
+    if (sty.flags.strikethrough) flags |= 1 << 3;
+    if (sty.flags.inverse) flags |= 1 << 4;
+    if (sty.flags.invisible) flags |= 1 << 5;
+    if (sty.flags.blink) flags |= 1 << 6;
+    if (sty.flags.faint) flags |= 1 << 7;
+
+    const grapheme_len: u8 = if (cell.hasGrapheme())
+        if (page.lookupGrapheme(cell)) |cps| @min(@as(u8, @intCast(cps.len)), 255) else 0
+    else
+        0;
+
+    return .{
+        .codepoint = cell.codepoint(),
+        .fg_r = fg.r,
+        .fg_g = fg.g,
+        .fg_b = fg.b,
+        .bg_r = bg.r,
+        .bg_g = bg.g,
+        .bg_b = bg.b,
+        .flags = flags,
+        .width = switch (cell.wide) {
+            .narrow => 1,
+            .wide => 2,
+            .spacer_tail, .spacer_head => 0,
+        },
+        .hyperlink_id = if (cell.hyperlink) 1 else 0,
+        .grapheme_len = grapheme_len,
+    };
+}
+
+fn defaultCell(fg_default: color.RGB, bg_default: color.RGB) GhosttyCell {
+    return .{
+        .codepoint = 0,
+        .fg_r = fg_default.r,
+        .fg_g = fg_default.g,
+        .fg_b = fg_default.b,
+        .bg_r = bg_default.r,
+        .bg_g = bg_default.g,
+        .bg_b = bg_default.b,
+        .flags = 0,
+        .width = 1,
+        .hyperlink_id = 0,
+    };
+}
+
+/// Get ALL viewport cells in one call.
+/// Returns total cells written (rows * cols), or -1 on error.
+pub fn getViewport(
+    ptr: ?*anyopaque,
+    out: [*]GhosttyCell,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    const t = &wrapper.terminal;
+    const rows: usize = t.rows;
+    const cols: usize = t.cols;
+    const total: usize = rows * cols;
+    const palette = &t.color_palette.colors;
+
+    if (buf_size < total) return -1;
+
+    const pages = &t.screen.pages;
+
+    var idx: usize = 0;
+    for (0..rows) |y| {
+        const pin = pages.pin(.{ .active = .{ .y = @intCast(y) } }) orelse {
+            for (0..cols) |_| {
+                out[idx] = defaultCell(wrapper.fg_color, wrapper.bg_color);
+                idx += 1;
+            }
+            continue;
+        };
+
+        const cells = pin.cells(.all);
+        const page = &pin.node.data;
+
+        for (0..cols) |x| {
+            if (x >= cells.len) {
+                out[idx] = defaultCell(wrapper.fg_color, wrapper.bg_color);
+                idx += 1;
+                continue;
+            }
+
+            out[idx] = resolveCell(&cells[x], page, wrapper.fg_color, wrapper.bg_color, palette);
+            idx += 1;
+        }
+    }
+
+    return @intCast(total);
+}
+
+/// Get grapheme codepoints for a cell at (row, col).
+pub fn getGrapheme(
+    ptr: ?*anyopaque,
+    row: c_int,
+    col: c_int,
+    out: [*]u32,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    const t = &wrapper.terminal;
+
+    if (row < 0 or col < 0) return -1;
+    if (@as(usize, @intCast(row)) >= t.rows) return -1;
+    if (@as(usize, @intCast(col)) >= t.cols) return -1;
+    if (buf_size < 1) return -1;
+
+    const pages = &t.screen.pages;
+    const pin = pages.pin(.{ .active = .{ .y = @intCast(row) } }) orelse return -1;
+
+    const cells = pin.cells(.all);
+    const x: usize = @intCast(col);
+    if (x >= cells.len) return -1;
+
+    const cell = &cells[x];
+    out[0] = cell.codepoint();
+    var count: usize = 1;
+
+    if (cell.hasGrapheme()) {
+        if (pin.node.data.lookupGrapheme(cell)) |cps| {
+            for (cps) |cp| {
+                if (count >= buf_size) break;
+                out[count] = cp;
+                count += 1;
+            }
+        }
+    }
+
+    return @intCast(count);
+}
